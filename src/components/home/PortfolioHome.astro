---
import { homeContent } from '../../data/home';

const { hero, positioning, careerHighlights, projects, skills, contact } = homeContent;
---

<div class="home-page">
  <section class="home-hero">
    <div class="home-hero__content">
      <p class="eyebrow">{hero.eyebrow}</p>
      <div class="home-hero__title-block">
        <h1>{hero.title}</h1>
        <p class="home-hero__intro">{hero.intro}</p>
      </div>

      <div class="home-hero__actions">
        <a class="button button--primary" href={hero.primaryCta.href}>{hero.primaryCta.label}</a>
        <a class="button button--secondary" href={hero.secondaryCta.href}>{hero.secondaryCta.label}</a>
      </div>

      <nav class="home-anchor-nav" aria-label="Homepage sections">
        {hero.anchorLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
    </div>

    <aside class="home-hero__panel">
      <p class="home-hero__badge">{hero.badge}</p>
      <p class="home-hero__panel-label">Current focus</p>
      <ul class="home-hero__focus-list">
        {hero.focus.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </aside>
  </section>

  <section id="positioning" class="home-section home-section--split">
    <div class="section-heading">
      <p class="eyebrow">{positioning.eyebrow}</p>
      <h2>{positioning.title}</h2>
    </div>
    <div class="home-copy-card">
      <p>{positioning.text}</p>
      <p class="home-copy-card__note">{positioning.note}</p>
    </div>
  </section>

  <section id="career" class="home-section">
    <div class="section-heading">
      <p class="eyebrow">Selected experience</p>
      <h2>Career highlights that support the new positioning.</h2>
    </div>
    <div class="home-card-grid home-card-grid--three">
      {careerHighlights.map((item) => (
        <article class="home-info-card">
          <p class="home-info-card__meta">{item.period}</p>
          <h3>{item.role}</h3>
          <p class="home-info-card__subtle">{item.company}</p>
          <p>{item.description}</p>
          <p class="home-info-card__impact">{item.impact}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="projects" class="home-section">
    <div class="section-heading">
      <p class="eyebrow">Selected projects</p>
      <h2>Evidence of the systems, platforms, and delivery standards behind the brand.</h2>
    </div>
    <div class="home-card-grid home-card-grid--projects">
      {projects.map((project) => (
        <article class="home-project-card">
          <div class="home-project-card__header">
            <span class="home-pill">{project.category}</span>
            <a href={project.href}>Open work</a>
          </div>
          <h3>{project.title}</h3>
          <p>{project.summary}</p>
          <p class="home-project-card__impact">{project.impact}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="skills" class="home-section home-section--skills">
    <div class="section-heading">
      <p class="eyebrow">Skills</p>
      <h2>Tech highlights organized as readable capability groups.</h2>
    </div>
    <div class="home-skill-groups">
      {skills.map((group) => (
        <article class="home-skill-group">
          <h3>{group.group}</h3>
          <div class="home-skill-group__items">
            {group.items.map((item) => (
              <span class="home-pill home-pill--soft">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="contact" class="home-section home-contact">
    <div class="home-contact__content">
      <p class="eyebrow">{contact.eyebrow}</p>
      <h2>{contact.title}</h2>
      <p>{contact.text}</p>

      <div class="home-hero__actions home-hero__actions--compact">
        <a class="button button--primary" href={contact.primary.href}>{contact.primary.label}</a>
        <a class="button button--secondary" href={contact.secondary.href} target="_blank" rel="noreferrer">
          {contact.secondary.label}
        </a>
      </div>
    </div>

    <aside class="home-contact__notes">
      {contact.notes.map((note) => (
        <p>{note}</p>
      ))}
    </aside>
  </section>
</div>

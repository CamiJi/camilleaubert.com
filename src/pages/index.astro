---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Camille Aubert — Portfolio">
  <section class="hero">
    <p class="eyebrow">Portfolio</p>
    <h1>Building digital experiences with clarity and care.</h1>
    <p class="intro">
      I work across product, content, and implementation to turn ideas into simple and useful web
      experiences. This site is the evolving home for my work, my background, and selected
      projects.
    </p>
  </section>

  <section class="content-section">
    <h2>What you will find here</h2>
    <p>
      A short presentation of my profile, a first selection of projects, and a simple way to get in
      touch for collaboration or opportunities.
    </p>
  </section>
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About — Camille Aubert">
  <section class="hero">
    <p class="eyebrow">About</p>
    <h1>About Camille Aubert</h1>
    <p class="intro">
      I am building a portfolio that reflects a mix of strategy, structure, content thinking, and web
      execution. I care about maintainable systems, clear communication, and elegant digital
      experiences.
    </p>
  </section>

  <section class="content-section">
    <h2>Approach</h2>
    <p>
      I like projects where content, design, and technical implementation are aligned from the start.
      My goal is to build pages and products that are understandable, coherent, and useful.
    </p>
  </section>
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';

const projects = [
  {
    title: 'Industrial RAG Infrastructure',
    context:
      'Deploying generative AI systems for mission-critical knowledge management within the Cegos Group.',
    role: 'Solution Architect & Lead Developer',
    stack: 'AWS Bedrock, OpenAI API, Python, RAG Frameworks.',
    outcome:
      'Achieved a 95% accuracy rate for business-critical data retrieval and automated decision-making.',
    link: 'https://www.cegos.fr',
  },
  {
    title: 'Cegos Enterprise Platform',
    context:
      'Directing the architectural evolution of the primary platform for Europe\'s leader in professional training.',
    role: 'Transversal Architect / Lead Developer',
    stack: 'Laravel, WordPress, Gutenberg, Docker, AWS.',
    outcome:
      'Successfully migrated to a containerized infrastructure, ensuring seamless scalability for millions of users.',
    link: 'https://www.cegos.fr',
  },
  {
    title: 'Technical Performance Lab',
    context:
      'Developed lamaisonmontparnasse.fr as a dedicated research lab for extreme SEO and conversion optimization.',
    role: 'Full-stack Developer & Technical SEO Specialist',
    stack: 'PHP, Custom Gutenberg Blocks, High-speed rendering.',
    outcome:
      'Delivered record-breaking performance scores and a highly optimized user acquisition funnel.',
    link: 'https://lamaisonmontparnasse.fr',
  },
];
---

<MainLayout
  title="Projects — Camille Aubert"
  description="Selected projects from Camille Aubert covering industrial RAG systems, enterprise platform architecture, and high-performance web delivery."
>
  <section class="hero">
    <p class="eyebrow">Projects</p>
    <h1>Selected work</h1>
    <p class="intro">
      A selection of projects focused on AI architecture, enterprise-scale platforms, and
      performance-driven web engineering.
    </p>
  </section>

  <section class="content-section">
    <ul class="project-list">
      {projects.map((project) => (
        <li class="project-card">
          <div class="project-card__header">
            <h2>{project.title}</h2>
            <a href={project.link} target="_blank" rel="noreferrer">Visit project</a>
          </div>
          <p><strong>Context:</strong> {project.context}</p>
          <p><strong>Role:</strong> {project.role}</p>
          <p><strong>Stack:</strong> {project.stack}</p>
          <p><strong>Outcome:</strong> {project.outcome}</p>
        </li>
      ))}
    </ul>
  </section>
</MainLayout>

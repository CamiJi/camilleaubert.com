---
import '../styles/global.css'
import { SITE_CONFIG } from '../config.ts';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const siteUrl = 'https://camilleaubert.com';
const ogImage = `${siteUrl}/og-image.webp`;
const authorName = 'Camille Aubert';
const baseTheme = SITE_CONFIG.baseTheme;
const defaultTheme = `${baseTheme}-dark`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="canonical" href={siteUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={authorName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Camille Aubert",
        "jobTitle": "AI Solutions Architect & Lead Full-Stack Developer",
        "url": "https://camilleaubert.com",
        "sameAs": [
          "https://github.com/CamiJi",
          "https://www.linkedin.com/in/camille-aubert-27760a56/"
        ],
        "email": "mailto:aubertcam@gmail.com",
        "image": "https://camilleaubert.com/og-image.webp"
      }
    </script>

    <!-- THEME TOGGLE SCRIPT -->
    <script is:inline define:vars={{ baseTheme, defaultTheme }}>
      const savedTheme = localStorage.getItem('theme');

      if (savedTheme && savedTheme.startsWith(baseTheme)) {
        document.documentElement.setAttribute('data-theme', savedTheme);
      } else {
        document.documentElement.setAttribute('data-theme', defaultTheme);
        localStorage.setItem('theme', defaultTheme);
      }
    </script>

  </head>
  <body class="bg-container relative min-h-screen overflow-x-hidden antialiased">
    <!-- Skip to content -->
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg focus:outline-none"
    >
      Skip to main content
    </a>

    <div 
      id="matrix-container"
      aria-hidden="true" 
      class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none"
      style="mask-image: linear-gradient(to bottom, black 0%, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 80%, transparent 100%);"
    ></div>

    <main id="main-content" class="px-2 sm:px-12 md:px-14 lg:px-28 max-w-360 mx-auto relative z-0">
        <slot />
    </main>

    <button
      id="to-top"
      class="fixed bottom-8 right-8 z-50 p-0 rounded-full bg-background border border-accent/10 shadow-2xl transition-all duration-500 translate-y-20 opacity-0 group flex items-center justify-center cursor-pointer"
      aria-label="Back to top"
    >
      <svg class="w-14 h-14 -rotate-90">
        <circle cx="28" cy="28" r="24" fill="none" stroke="currentColor" stroke-width="3" class="text-accent/5"></circle>
        <circle
          id="progress-circle"
          cx="28" cy="28" r="24"
          fill="none"
          stroke="currentColor" 
          stroke-width="3"
          stroke-dasharray="150.7"
          stroke-dashoffset="150.7"
          stroke-linecap="round"
          class="text-accent transition-all duration-100"
        ></circle>
      </svg>
      
      <div class="absolute text-accent group-hover:scale-110 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M13.0001 7.82843V20H11.0001V7.82843L5.63614 13.1924L4.22192 11.7782L12.0001 4L19.7783 11.7782L18.3641 13.1924L13.0001 7.82843Z"></path>
        </svg>
      </div>
    </button>

    <script defer src="/scripts/matrix.js"></script>
  </body>
</html>

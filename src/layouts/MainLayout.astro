---
import '../styles/global.css';
import SiteHeader from '../components/ui/SiteHeader.astro';
import SiteFooter from '../components/ui/SiteFooter.astro';

interface Props {
  title?: string;
}

const { title = 'Camille Aubert' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
